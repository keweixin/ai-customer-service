# ============================================================
# AI 客服系统 环境变量模板
# ============================================================
# 使用方法:复制本文件为 .env,填入真实值
#   cp .env.example .env
# 警告:.env 文件含敏感信息,已在 .gitignore 中忽略,绝不提交 Git
# ============================================================

# --- 应用配置 ---
APP_NAME=AI Customer Service
APP_ENV=development  # development / staging / production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO  # DEBUG / INFO / WARNING / ERROR

# --- 火山方舟 LLM 配置 ---
# 在火山引擎控制台获取:https://console.volcengine.com/ark
ARK_API_KEY=your_ark_api_key_here
ARK_MODEL=deepseek-v4-flash
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
# LLM 调用参数
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# --- Embedding 配置(用于 RAG 向量化)---
ARK_EMBEDDING_MODEL=ep-embedding-xxx  # 方舟 embedding 接入点 ID
EMBEDDING_DIMENSION=1024

# --- PostgreSQL 配置 ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aics
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ai_customer_service
# SQLAlchemy 连接串(自动拼接,一般不用改)
DATABASE_URL=postgresql+asyncpg://aics:change_me_in_production@localhost:5432/ai_customer_service

# --- JWT 鉴权 ---
JWT_SECRET_KEY=change_me_to_a_random_64_char_string  # 生产环境必须改成随机长串
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 小时

# --- CORS(前端域名白名单,逗号分隔)---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- 限流 ---
RATE_LIMIT_PER_MINUTE=60

# --- RAG 配置 ---
RAG_CHUNK_SIZE=500       # 文档切块大小(字符数)
RAG_CHUNK_OVERLAP=50     # 块之间重叠字符数
RAG_TOP_K=5              # 检索返回 top-k 片段
RAG_MIN_SIMILARITY=0.7   # 最低相似度阈值
